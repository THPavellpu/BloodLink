# ============================================
# BLOODLINK BACKEND ENVIRONMENT CONFIGURATION
# ============================================

# ========== DJANGO CORE SETTINGS ==========
# Secret key for Django - MUST be changed for production!
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-change-in-production

# Debug mode - MUST be False in production
DEBUG=False

# Allowed hosts - comma separated
# For production on Render: your-app-name.onrender.com
# For development: localhost,127.0.0.1,0.0.0.0
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,your-app-name.onrender.com

# ========== DATABASE CONFIGURATION ==========
# For PostgreSQL on Render, use:
# DATABASE_URL=postgresql://user:password@host:port/dbname
# Render will automatically provide this variable
# If not set, falls back to SQLite for development
DATABASE_URL=postgresql://user:password@localhost:5432/bloodlink_db

# ========== CORS & SECURITY ==========
# CORS allowed origins - comma separated
# For development: include localhost and test servers
# For production: your-frontend-domain.com, your-app.onrender.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1,https://your-frontend-domain.com

# CSRF trusted origins - comma separated
# Must include your frontend domain and API domain
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:8080,https://your-frontend-domain.com,https://your-app-name.onrender.com

# SSL/HTTPS Settings (set to True in production)
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# HSTS Settings (only for HTTPS)
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# ========== JWT SETTINGS ==========
# Access token lifetime in hours (default 24)
# SIMPLE_JWT_ACCESS_TOKEN_LIFETIME=24

# ========== API KEYS ==========
# Gemini AI API Key
GEMINI_API_KEY=your-gemini-api-key-here

# Firebase Service Account JSON path (optional)
# Uncomment and set path if using Firebase in production
# FIREBASE_CREDENTIALS=/path/to/firebase-credentials.json

# ========== LOGGING ==========
# Django log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
DJANGO_LOG_LEVEL=INFO

# ========== EMAIL CONFIGURATION (optional) ==========
# For future email notifications
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password

# ========== DEPLOYMENT NOTES ==========
# For Render Deployment:
# 1. Set SECRET_KEY to a strong random value
# 2. Set DEBUG=False
# 3. Set ALLOWED_HOSTS to your Render URL
# 4. Add DATABASE_URL (Render provides this automatically)
# 5. Set CORS_ALLOWED_ORIGINS for your frontend
# 6. Set CSRF_TRUSTED_ORIGINS for form submissions
# 7. Enable SECURE_SSL_REDIRECT, SESSION_COOKIE_SECURE, CSRF_COOKIE_SECURE
# 8. Set API keys for Gemini and Firebase as needed

